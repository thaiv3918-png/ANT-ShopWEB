@model Employee
@{
    ViewBag.Title = "Mật khẩu nhân viên";
}

@section PageToolBar {
    <button type="submit" form="formChangePassword" class="btn btn-primary">
        <i class="bi bi-key me-1"></i>
        Đổi mật khẩu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-warning card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-lock me-2"></i>
                    Đổi mật khẩu nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangePassword" method="post">
                    <input type="hidden" name="id" value="@Model.EmployeeID" />
                    <!-- Thông báo -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <strong><i class="bi bi-exclamation-triangle"></i> Lỗi:</strong>
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div class="mt-1">@error.ErrorMessage</div>
                            }
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                      <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-person me-1"></i>
                            Thông tin nhân viên
                        </legend>

                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9">@Model.FullName</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@Model.Email</dd>

                            <dt class="col-sm-3">Trạng thái</dt>
                            <dd class="col-sm-9">
                                @if (Model.IsWorking)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Đã nghỉ việc</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-key me-1"></i>
                            Thông tin mật khẩu
                        </legend>
                        <div class="alert alert-warning mb-3">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Lưu ý:</strong> Chức năng này dùng để cấp mật khẩu mới cho nhân viên
                            (khi nhân viên quên mật khẩu hoặc cần reset mật khẩu).
                        </div>
                        <div class="mb-3">
                            <label for="newPassword" class="form-label">Mật khẩu mới <span class="text-danger">*</span></label>
                            <input type="password" class="form-control @(ViewData.ModelState.ContainsKey("newPassword") ? "is-invalid" : "")"
                                   id="newPassword" name="newPassword" required autofocus />
                            @if (ViewData.ModelState.ContainsKey("newPassword"))
                            {
                                <div class="invalid-feedback d-block">
                                    @ViewData.ModelState["newPassword"].Errors.FirstOrDefault()?.ErrorMessage
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <label for="confirmPassword" class="form-label">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                            <input type="password" class="form-control @(ViewData.ModelState.ContainsKey("confirmPassword") ? "is-invalid" : "")"
                                   id="confirmPassword" name="confirmPassword" required />
                            <div class="form-text">Nhập lại mật khẩu mới để xác nhận.</div>
                            @if (ViewData.ModelState.ContainsKey("confirmPassword"))
                            {
                                <div class="invalid-feedback d-block">
                                    @ViewData.ModelState["confirmPassword"].Errors.FirstOrDefault()?.ErrorMessage
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="showPassword">
                                <label class="form-check-label" for="showPassword">Hiển thị mật khẩu</label>
                            </div>
                        </div>

                        <hr />

                        <div class="alert alert-secondary">
                            <i class="bi bi-shield-check me-2"></i>
                            <strong>Gợi ý mật khẩu mạnh:</strong>
                            <ul class="mb-0 mt-2">
                                <li>Ít nhất 8 ký tự</li>
                                <li>Bao gồm chữ hoa, chữ thường</li>
                                <li>Bao gồm số và ký tự đặc biệt</li>
                            </ul>
                        </div>
                    </fieldset>

                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        // Toggle hiển thị mật khẩu
        document.getElementById('showPassword').addEventListener('change', function() {
            const passwordFields = ['currentPassword', 'newPassword', 'confirmPassword'];
            passwordFields.forEach(field => {
                const input = document.getElementById(field);
                if (input) {
                    input.type = this.checked ? 'text' : 'password';
                }
            });
        });

        // Validate form trước khi submit
        document.getElementById('formChangePassword').addEventListener('submit', function(e) {
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;

            if (newPassword !== confirmPassword) {
                e.preventDefault();
                alert('Mật khẩu xác nhận không khớp!');
                return false;
            }

            if (newPassword.length < 6) {
                e.preventDefault();
                alert('Mật khẩu phải có ít nhất 6 ký tự!');
                return false;
            }

            return true;
        });
    </script>
}