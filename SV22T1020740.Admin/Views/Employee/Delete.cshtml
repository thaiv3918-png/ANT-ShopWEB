@model Employee
@{
    
}
@section PageToolBar {
    @if ((bool?)ViewBag.CanDelete == true)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash"></i> Xóa
        </button>
    }

    <a href="/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="card card-danger">
    <div class="card-header">
        <h3 class="card-title">
            <i class="bi bi-person-x"></i>
            @( (bool?)ViewBag.CanDelete == true ? "Xác nhận xóa nhân viên" : "Lưu ý")
        </h3>
    </div>

    <div class="card-body">
        <form id="formDelete" method="post" action="~/Employee/Delete/@Model.EmployeeID">
            @if ((bool?)ViewBag.CanDelete == true)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i>
                    Bạn có chắc chắn muốn xóa nhân viên này không?
                </div>
            }
            else
            {
                <div class="alert alert-info d-flex align-items-center">
                    <i class="bi bi-info-circle me-2"></i>
                    Nhân viên đang làm việc, không thể xóa.
                </div>
            }
            
            <div class="row">
                <div class="col-md-2 text-start">
                    <img src="~/images/employees/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                         class="img-thumbnail mb-2"
                         style="width: 100%;"
                         alt="Ảnh nhân viên" />
                </div>

                <div class="col-md-10">
                    <dl class="row">
                        <dt class="col-sm-3">Họ và tên:</dt>
                        <dd class="col-sm-9">@Model.FullName</dd>

                        <dt class="col-sm-3">Ngày sinh:</dt>
                        <dd class="col-sm-9">@Model.BirthDate</dd>

                        <dt class="col-sm-3">Điện thoại:</dt>
                        <dd class="col-sm-9">@Model.Phone</dd>

                        <dt class="col-sm-3">Email:</dt>
                        <dd class="col-sm-9">@Model.Email</dd>

                        <dt class="col-sm-3">Địa chỉ:</dt>
                        <dd class="col-sm-9">@Model.Address</dd>

                        <dt class="col-sm-3">Trạng thái:</dt>
                        <dd class="col-sm-9">
                            @if (Model.IsWorking)
                            {
                                <td class="text-center">
                                    <span class="badge bg-success">Đang làm việc</span>
                                </td>
                            }
                            else
                            {
                                <td class="text-center">
                                    <span class="badge bg-warning">Đã nghỉ việc</span>
                                </td>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </form>
    </div>
</div>
