@model SV22T1020740.Models.HR.Employee

@{
    ViewBag.Title = "Phân quyền nhân viên";
    // Xử lý an toàn với null
    var rolesString = ViewBag.CurrentRoles as string ?? "";
    var roles = string.IsNullOrEmpty(rolesString) ? new string[0] : rolesString.Split(';', StringSplitOptions.RemoveEmptyEntries);
}

@section PageToolBar {
    <button type="submit" form="formChangeRole" class="btn btn-primary">
        <i class="bi bi-shield-check me-1"></i>
        Lưu phân quyền
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-check me-2"></i>
                    Phân quyền cho nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangeRole" method="post">

                    <!-- hidden id nằm trong form -->
                    <input type="hidden" name="id" value="@ViewBag.EmployeeID" />

                    <!-- note -->
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    }

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <!-- INFO - Kiểm tra Model không null -->
                    @if (Model != null)
                    {
                        <fieldset class="mb-4">
                            <legend class="fs-6 text-muted mb-3">
                                <i class="bi bi-person me-1"></i>
                                Thông tin nhân viên
                            </legend>

                            <dl class="row mb-0">
                                <dt class="col-sm-3">Họ và tên</dt>
                                <dd class="col-sm-9">@Model.FullName</dd>

                                <dt class="col-sm-3">Email</dt>
                                <dd class="col-sm-9">@Model.Email</dd>

                                <dt class="col-sm-3">Trạng thái</dt>
                                <dd class="col-sm-9">
                                    @if (Model.IsWorking)
                                    {
                                        <span class="badge bg-success">Đang làm việc</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Đã nghỉ việc</span>
                                    }
                                </dd>
                            </dl>
                        </fieldset>
                    }

                    <!-- ROLES -->
                    <fieldset>
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-shield-lock me-1"></i>
                            Danh sách quyền
                        </legend>

                        <table class="table table-bordered table-hover align-middle">
                            <thead class="table-secondary">
                                <tr>
                                    <th style="width:60px;" class="text-center">Chọn</th>
                                    <th>Tên quyền</th>
                                    <th>Mô tả quyền</th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox" name="roles" value="customer"
                                               @(Array.Exists(roles, r => r == "customer") ? "checked" : "") />
                                    </td>
                                    <td>Quản lý khách hàng</td>
                                    <td>Thêm, sửa, xóa khách hàng</td>
                                </tr>

                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox" name="roles" value="product"
                                               @(Array.Exists(roles, r => r == "product") ? "checked" : "") />
                                    </td>
                                    <td>Quản lý mặt hàng</td>
                                    <td>Quản lý sản phẩm</td>
                                </tr>

                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox" name="roles" value="category"
                                               @(Array.Exists(roles, r => r == "category") ? "checked" : "") />
                                    </td>
                                    <td>Quản lý loại hàng</td>
                                    <td>Quản lý category</td>
                                </tr>

                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox" name="roles" value="employee"
                                               @(Array.Exists(roles, r => r == "employee") ? "checked" : "") />
                                    </td>
                                    <td>Quản lý nhân viên</td>
                                    <td>Quản lý nhân viên</td>
                                </tr>

                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox" name="roles" value="order"
                                               @(Array.Exists(roles, r => r == "order") ? "checked" : "") />
                                    </td>
                                    <td>Quản lý đơn hàng</td>
                                    <td>Xử lý đơn hàng</td>
                                </tr>

                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox" name="roles" value="admin"
                                               @(Array.Exists(roles, r => r == "admin") ? "checked" : "") />
                                    </td>
                                    <td>Quản trị hệ thống</td>
                                    <td>Toàn quyền</td>
                                </tr>
                            </tbody>
                        </table>
                    </fieldset>

                </form>
            </div>
        </div>
    </div>
</div>