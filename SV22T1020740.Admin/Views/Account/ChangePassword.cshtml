@{
    ViewBag.Title = "Đổi mật khẩu";
}

@section PageToolBar {
    <button type="submit" form="formChangePassword" class="btn btn-primary">
        <i class="bi bi-key me-1"></i>
        Đổi mật khẩu
    </button>
    <a href="~/" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card card-warning card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-key me-2"></i>
                    Đổi mật khẩu tài khoản
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangePassword" method="post">
                    
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <strong><i class="bi bi-exclamation-triangle"></i> Lỗi:</strong>
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div class="mt-1">@error.ErrorMessage</div>
                            }
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                   
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    
                    <div class="alert alert-info mb-4">
                        <i class="bi bi-person-circle me-2"></i>
                        <strong>Tài khoản:</strong> @User.Identity.Name
                    </div>

                    <div class="mb-3">
                        <label for="currentPassword" class="form-label">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-lock-fill"></i>
                            </span>
                            <input type="password" class="form-control"
                                   id="currentPassword" name="currentPassword"
                                   placeholder="Nhập mật khẩu hiện tại" autofocus />
                        </div>
                        <div class="form-text">Vui lòng nhập mật khẩu hiện tại của bạn.</div>
                        @if (ViewData.ModelState.ContainsKey("currentPassword"))
                        {
                            <div class="invalid-feedback d-block">
                                @ViewData.ModelState["currentPassword"].Errors.FirstOrDefault()?.ErrorMessage
                            </div>
                        }
                    </div>

                    
                    <div class="mb-3">
                        <label for="newPassword" class="form-label">Mật khẩu mới <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-shield-lock-fill"></i>
                            </span>
                            <input type="password" class="form-control"
                                   id="newPassword" name="newPassword"
                                   placeholder="Nhập mật khẩu mới" />
                        </div>
                        <div class="form-text">Mật khẩu phải có ít nhất 6 ký tự và không trùng với mật khẩu hiện tại.</div>
                        @if (ViewData.ModelState.ContainsKey("newPassword"))
                        {
                            <div class="invalid-feedback d-block">
                                @ViewData.ModelState["newPassword"].Errors.FirstOrDefault()?.ErrorMessage
                            </div>
                        }
                        
                        <div id="passwordStrength" class="mt-2 small"></div>
                    </div>

                    
                    <div class="mb-3">
                        <label for="confirmPassword" class="form-label">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-check-circle-fill"></i>
                            </span>
                            <input type="password" class="form-control"
                                   id="confirmPassword" name="confirmPassword"
                                   placeholder="Nhập lại mật khẩu mới" />
                        </div>
                        <div class="form-text">Nhập lại mật khẩu mới để xác nhận.</div>
                        @if (ViewData.ModelState.ContainsKey("confirmPassword"))
                        {
                            <div class="invalid-feedback d-block">
                                @ViewData.ModelState["confirmPassword"].Errors.FirstOrDefault()?.ErrorMessage
                            </div>
                        }
                    </div>

                    <!--hiển thị mật khẩu -->
                    <div class="mb-3">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="showPassword" />
                            <label class="form-check-label" for="showPassword">
                                <i class="bi bi-eye"></i> Hiển thị mật khẩu
                            </label>
                        </div>
                    </div>

                    <!-- Lưu ý bảo mật -->
                    <div class="alert alert-warning mt-3">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Lưu ý:</strong> Sau khi đổi mật khẩu thành công, bạn sẽ cần đăng nhập lại bằng mật khẩu mới.
                    </div>

                    <div class="alert alert-secondary mt-3">
                        <i class="bi bi-shield-check me-2"></i>
                        <strong>Gợi ý mật khẩu mạnh:</strong>
                        <ul class="mb-0 mt-2">
                            <li>Ít nhất 8 ký tự</li>
                            <li>Bao gồm chữ hoa, chữ thường</li>
                            <li>Bao gồm số và ký tự đặc biệt (ví dụ: @@, #, $, %, ...)</li>
                            <li>Không nên dùng thông tin cá nhân (tên, ngày sinh,...)</li>
                        </ul>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // hiển thị mật khẩu
        var showPasswordCheckbox = document.getElementById('showPassword');
        if (showPasswordCheckbox) {
            showPasswordCheckbox.addEventListener('change', function() {
                var passwordFields = ['currentPassword', 'newPassword', 'confirmPassword'];
                for (var i = 0; i < passwordFields.length; i++) {
                    var input = document.getElementById(passwordFields[i]);
                    if (input) {
                        input.type = this.checked ? 'text' : 'password';
                    }
                }
            });
        }

        // Đánh giá độ mạnh của mật khẩu mới
        var newPasswordInput = document.getElementById('newPassword');
        if (newPasswordInput) {
            newPasswordInput.addEventListener('input', function() {
                var password = this.value;
                var strength = 0;
                var strengthText = '';
                var strengthClass = '';

                // Kiểm tra độ dài
                if (password.length >= 8) strength++;

                // Kiểm tra chữ hoa
                if (password.match(/[A-Z]/)) strength++;

                // Kiểm tra chữ thường
                if (password.match(/[a-z]/)) strength++;

                // Kiểm tra số
                if (password.match(/[0-9]/)) strength++;

                // Kiểm tra ký tự đặc biệt
                if (password.match(/[^A-Za-z0-9]/)) strength++;

                // Xác định độ mạnh
                if (password.length === 0) {
                    strengthText = '';
                    strengthClass = '';
                } else if (strength <= 2) {
                    strengthText = '🔴 Yếu - Nên chọn mật khẩu mạnh hơn';
                    strengthClass = 'text-danger';
                } else if (strength <= 3) {
                    strengthText = '🟡 Trung bình';
                    strengthClass = 'text-warning';
                } else if (strength <= 4) {
                    strengthText = '🟢 Mạnh';
                    strengthClass = 'text-success';
                } else {
                    strengthText = '💪 Rất mạnh - Tốt!';
                    strengthClass = 'text-success fw-bold';
                }

                // Hiển thị đánh giá
                var strengthIndicator = document.getElementById('passwordStrength');
                if (strengthIndicator) {
                    strengthIndicator.innerHTML = strengthText;
                    strengthIndicator.className = 'mt-2 small ' + strengthClass;
                }
            });
        }

        // Validate form trước khi submit
        var form = document.getElementById('formChangePassword');
        if (form) {
            form.addEventListener('submit', function(e) {
                var currentPassword = document.getElementById('currentPassword').value;
                var newPassword = document.getElementById('newPassword').value;
                var confirmPassword = document.getElementById('confirmPassword').value;

                // Kiểm tra mật khẩu hiện tại
                if (!currentPassword) {
                    e.preventDefault();
                    alert('Vui lòng nhập mật khẩu hiện tại!');
                    document.getElementById('currentPassword').focus();
                    return false;
                }

                // Kiểm tra mật khẩu mới
                if (!newPassword) {
                    e.preventDefault();
                    alert('Vui lòng nhập mật khẩu mới!');
                    document.getElementById('newPassword').focus();
                    return false;
                }

                // Kiểm tra độ dài mật khẩu mới
                if (newPassword.length < 6) {
                    e.preventDefault();
                    alert('Mật khẩu mới phải có ít nhất 6 ký tự!');
                    document.getElementById('newPassword').focus();
                    return false;
                }

                // Kiểm tra mật khẩu mới không trùng với mật khẩu cũ
                if (newPassword === currentPassword) {
                    e.preventDefault();
                    alert('Mật khẩu mới không được trùng với mật khẩu hiện tại!');
                    document.getElementById('newPassword').focus();
                    return false;
                }

                // Kiểm tra xác nhận mật khẩu
                if (newPassword !== confirmPassword) {
                    e.preventDefault();
                    alert('Mật khẩu xác nhận không khớp!');
                    document.getElementById('confirmPassword').focus();
                    return false;
                }

                // Xác nhận trước khi đổi mật khẩu
                if (!confirm('Bạn có chắc chắn muốn đổi mật khẩu?\nSau khi đổi, bạn sẽ cần đăng nhập lại bằng mật khẩu mới.')) {
                    e.preventDefault();
                    return false;
                }

                return true;
            });
        }
    </script>
}