@model ProductSearchInput
@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <!-- Tìm kiếm & chọn mặt hàng -->
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <!-- Search -->
                <form id="formSearch"
                      method="get"
                      action="~/Order/SearchProduct"
                      data-target="searchResult"
                      onsubmit="paginationSearch(event, this, 1)">

                    <input type="hidden" asp-for="PageSize" />

                    <div class="input-group">
                        <input class="form-control"
                               asp-for="SearchValue"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <!-- Danh sách mặt hàng -->
                <div id="searchResult"></div>
            </div>
        </div>
    </div>

    <!-- Giỏ hàng và thông tin khách hàng -->
    <div class="col-8">
        <!-- Giỏ hàng -->
        <div class="row">
            <div class="col-12" id="cart">
            </div>
        </div>
        <!-- Thông tin khách hàng và nơi giao hàng -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <form onsubmit="createOrder(event,this)">
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="customer" asp-items="await SelectListHelper.CustomersAsync()">
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="province" asp-items="await SelectListHelper.ProvincesAsync()">
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea class="form-control" name="address"></textarea>
                                </div>
                            </div>

                            <div class="text-end">
                                <button class="btn btn-primary" type="submit">
                                    <i class="bi bi-check-circle"></i>
                                    Lập đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
            showCart();
        });
                function showCart() {
            fetch('/Order/ShowCart', {
                method: 'GET'
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Lỗi khi tải giỏ hàng');
                }
                return response.text();
            })
            .then(html => {
                document.getElementById('cart').innerHTML = html;
            })
            .catch(error => {
                console.error(error);
                document.getElementById('cart').innerHTML =
                    '<div class="text-danger">Không thể tải giỏ hàng</div>';
            });
        }
                function addCartItem(event, form) {
            event.preventDefault(); // chặn submit mặc định

            // Lấy dữ liệu từ form
            var formData = new FormData(form);

            fetch('/Order/AddCartItem', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Lỗi kết nối server');
                }
                return response.json();
            })
            .then(data => {
                if (data.code === 0) {
                    // Hiển thị lỗi
                    alert(data.message);
                } else {
                    // Thành công → reload giỏ hàng
                    showCart();
                }
            })
            .catch(error => {
                console.error(error);
                alert('Có lỗi xảy ra khi thêm vào giỏ hàng');
            });
        }
        function deleteCartItem(productId) {
            fetch('/Order/DeleteCartItem?productId=' + productId, {
                method: 'POST'
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Lỗi khi xóa sản phẩm');
                }
                return response.text();
            })
            .then(() => {
                showCart();
            })
            .catch(error => {
                console.error(error);
                alert('Không thể xóa sản phẩm khỏi giỏ hàng');
            });
        }
        function clearCart() {
            fetch('/Order/ClearCart', {
                method: 'POST'
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Lỗi khi xóa sản phẩm');
                }
                return response.text(); // hoặc json tùy API
            })
            .then(() => {
                // Sau khi xóa xong → reload giỏ hàng
                showCart();
            })
            .catch(error => {
                console.error(error);
                alert('Không thể xóa sản phẩm');
            });
        }
                function updateCartItem(event, form) {
            event.preventDefault(); // chặn submit mặc định

            var formData = new FormData(form);

            fetch('/Order/UpdateCartItem', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Lỗi kết nối server');
                }
                return response.json();
            })
            .then(data => {
                if (data.code === 0) {
                    // ❌ lỗi
                    alert(data.message);
                } else {
                    // ✅ thành công → đóng modal + reload cart

                    var modalElement = document.getElementById('dialogModal');
                    var modal = bootstrap.Modal.getInstance(modalElement);

                    if (modal) {
                        modal.hide();
                    }

                    showCart();
                }
            })
            .catch(error => {
                console.error(error);
                alert('Có lỗi xảy ra khi cập nhật giỏ hàng');
            });
        }
        function createOrder(event, form) {
            event.preventDefault(); // chặn submit mặc định

            var formData = new FormData(form);

            fetch('/Order/CreateOrder', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Lỗi kết nối server');
                }
                return response.json();
            })
            .then(data => {
                if (data.code === 0) {
                    // ❌ lỗi
                    alert(data.message);
                } else {
                    // ✅ thành công → chuyển trang
                    window.location.href = '/Order/Detail/' + data.code;
                }
            })
            .catch(error => {
                console.error(error);
                alert('Có lỗi xảy ra khi tạo đơn hàng');
            });
        }
    </script>
}