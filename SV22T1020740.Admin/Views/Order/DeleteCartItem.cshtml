@model OrderDetailViewInfo
@{
    Layout = null;
}
<div class="modal-header text-bg-danger">
    <strong class="modal-title">
        Xóa mặt hàng khỏi giỏ hàng
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <div class="alert alert-danger">
        <i class="bi bi-info-circle me-2"></i>
        Bạn có muốn xóa mặt hàng <b>@Model.ProductName</b> ra khỏi giỏ hàng không?
    </div>
</div>

<div class="modal-footer">
    <button class="btn btn-primary" data-bs-dismiss="modal" onclick="deleteCartItem(@Model.ProductID)">
        <i class="bi bi-check"></i> Chấp nhận
    </button>
    <button type="button"
            class="btn btn-secondary"
            data-bs-dismiss="modal">
        Đóng
    </button>
</div>