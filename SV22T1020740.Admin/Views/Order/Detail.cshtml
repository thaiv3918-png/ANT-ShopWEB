@model Order
@{
    ViewBag.Title = "Chi tiết đơn hàng";
}

@section PageToolBar {

    @if (Model.Status != OrderStatusEnum.Completed &&
                                                             Model.Status != OrderStatusEnum.Cancelled &&
                                                             Model.Status != OrderStatusEnum.Rejected)
    {
        <div class="btn-group">
            <button type="button"
                    class="btn btn-primary dropdown-toggle"
                    data-bs-toggle="dropdown">
                <i class="bi bi-gear me-1"></i>
                Xử lý đơn hàng
            </button>

            <ul class="dropdown-menu">

                @* NEW *@
                @if (Model.Status == OrderStatusEnum.New)
                {
                    <li>
                        <a class="dropdown-item open-modal"
                           href="~/Order/Accept/@Model.OrderID">
                            Duyệt đơn hàng
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item text-danger open-modal"
                           href="~/Order/Cancel/@Model.OrderID">
                            Hủy đơn hàng
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item text-danger open-modal"
                           href="~/Order/Reject/@Model.OrderID">
                            Từ chối đơn hàng
                        </a>
                    </li>
                }

                @* ACCEPTED *@
                @if (Model.Status == OrderStatusEnum.Accepted)
                {
                    <li>
                        <a class="dropdown-item open-modal"
                           href="~/Order/Shipping/@Model.OrderID">
                            Chuyển giao hàng
                        </a>
                    </li>

                    @* <li>
                        <a class="dropdown-item open-modal"
                           href="~/Order/Finish/@Model.OrderID">
                            Hoàn tất đơn hàng
                        </a>
                    </li> *@

                    <li>
                        <hr class="dropdown-divider">
                    </li>

                    <li>
                        <a class="dropdown-item text-danger open-modal"
                           href="~/Order/Cancel/@Model.OrderID">
                            Hủy đơn hàng
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item text-danger open-modal"
                           href="~/Order/Reject/@Model.OrderID">
                            Từ chối đơn hàng
                        </a>
                    </li>
                }

                @* SHIPPING *@
                @if (Model.Status == OrderStatusEnum.Shipping)
                {
                    <li>
                        <a class="dropdown-item open-modal"
                           href="~/Order/Finish/@Model.OrderID">
                            Hoàn tất đơn hàng
                        </a>
                    </li>
                }

            </ul>
        </div>
    }

    @* XÓA *@
    @if (Model.Status != OrderStatusEnum.Completed)
    {
        <a href="~/Order/Delete/@Model.OrderID"
           class="btn btn-danger ms-1 open-modal">
            <i class="bi bi-trash"></i>
            Xóa
        </a>
    }

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<!-- TRẠNG THÁI ĐƠN HÀNG -->
<div class="alert alert-info d-flex align-items-center mb-3">
    <i class="bi bi-info-circle fs-4 me-2"></i>
    <div>
        <strong>Trạng thái đơn hàng:</strong>
        @Model.Status.GetDescription()

        @if (Model.Status == OrderStatusEnum.Completed && Model.FinishedTime != null)
        {
            <span> lúc <b>@Model.FinishedTime</b></span>
        }
    </div>
</div>

<!-- THÔNG TIN ĐƠN HÀNG -->
<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-receipt me-2"></i>
            Thông tin đơn hàng
        </h5>
    </div>
    <input type="hidden" name="id" value="@Model.OrderID" />
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div>
            <div class="col-md-3">@Model.OrderID</div>

            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@Model.OrderTime</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div>
            <div class="col-md-3">@ViewBag.Employee?.FullName</div>

            <div class="col-md-3 fw-bold">Ngày nhận đơn</div>
            <div class="col-md-3">@Model.FinishedTime</div>
        </div>
    </div>
</div>

<!-- THÔNG TIN KHÁCH HÀNG -->
<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-person me-2"></i>
            Thông tin khách hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-3">@ViewBag.Customer?.CustomerName</div>

            <div class="col-md-3 fw-bold">Tên giao dịch</div>
            <div class="col-md-3">@ViewBag.Customer?.ContactName</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Email</div>
            <div class="col-md-9">@ViewBag.Customer?.Email</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Địa chỉ</div>
            <div class="col-md-9">@ViewBag.Customer?.Address</div>
        </div>
    </div>
</div>

<!-- THÔNG TIN GIAO HÀNG -->
<div class="card card-success card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-truck me-2"></i>
            Thông tin giao hàng
        </h5>
    </div>

    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Người giao hàng</div>
            <div class="col-md-3">@ViewBag.Shipper?.ShipperName</div>

            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@ViewBag.Shipper?.Phone</div>
        </div>

        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ giao hàng</div>
            <div class="col-md-9">@Model.DeliveryAddress</div>
        </div>

        <div class="row">
            <div class="col-md-3 fw-bold">Tỉnh / Thành</div>
            <div class="col-md-9">@Model.DeliveryProvince</div>
        </div>
    </div>
</div>

<!-- DANH SÁCH MẶT HÀNG -->
<div class="card card-secondary card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-box-seam me-2"></i>
            Danh sách mặt hàng
        </h5>
    </div>

    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên hàng</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>
            <tbody>
                @{
                    int index = 1;
                    decimal total = 0;
                }

                @foreach (var item in ViewBag.OrderDetails)
                {
                    var amount = item.Quantity * item.SalePrice;
                    total += amount;

                    <tr>
                        <td class="text-center">@index</td>
                        <td>@item.ProductName</td>
                        <td class="text-center">@item.Unit</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@item.SalePrice.ToString("N0")</td>
                        <td class="text-end">@amount.ToString("N0")</td>
                        <td class="text-end">
                            @if (Model.Status == OrderStatusEnum.New)
                            {
                                <!--Cho phép sửa khi trạng thái là Đang chờ duyệt -->
                                <a href="~/Order/EditDetail/@Model.OrderID?productId=@item.ProductID"
                                   class="btn btn-sm btn-primary open-modal">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a href="~/Order/DeleteDetail/@Model.OrderID?productId=@item.ProductID"
                                   class="btn btn-sm btn-danger open-modal">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }
                            else
                            {
                                <!-- Disable -->
                                <button class="btn btn-sm btn-primary" disabled title="Không thể sửa đơn hàng ở trạng thái này">
                                    <i class="bi bi-pencil"></i>
                                </button>

                                <button class="btn btn-sm btn-danger" disabled title="Không thể xóa ở trạng thái này">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>

                    index++;
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng</th>
                    <th class="text-end">@total.ToString("N0")</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .card-body .row {
            border-bottom: 1px dotted #646464;
        }
    </style>
}
@section Scripts {
    <script>
        function submitOrderAction(event, form, url) {
            event.preventDefault();

            fetch(url, {
                method: 'POST',
                body: new FormData(form)
            })
            .then(res => res.json())
            .then(data => {
                if (data.code === 0) {
                    alert(data.message);
                } else {
                    bootstrap.Modal.getInstance(document.getElementById('dialogModal'))?.hide();
                    window.location.href = '/Order/Detail/' + data.code;
                }
            })
            .catch(() => alert('Lỗi hệ thống'));
        }
        function updateDetail(event, form) {
            event.preventDefault();

            var formData = new FormData(form);

            fetch('/Order/UpdateDetail', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Lỗi kết nối server');
                }
                return response.json();
            })
            .then(data => {
                if (data.code === 0) {
                    alert(data.message);
                } else {
                    bootstrap.Modal.getInstance(document.getElementById('dialogModal'))?.hide();

                    // 🔥 CASE QUAN TRỌNG
                    if (data.code === -1) {
                        // đơn bị xóa
                        alert("Đơn hàng đã bị xóa vì không còn sản phẩm");
                        window.location.href = '/Order';
                    } else {
                        // còn item → về lại detail
                        alert("Cập nhập thành công đơn hàng");
                        window.location.href = '/Order/Detail/' + data.code;
                    }
                }
            })
            .catch(error => {
                console.error(error);
                alert('Có lỗi xảy ra khi cập nhật');
            });
        }
    </script>
}