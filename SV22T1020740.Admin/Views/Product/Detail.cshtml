@{
    Layout = "_Layout";
    ViewBag.Title = "Chi tiết mặt hàng";
}

<div class="row">

    <!-- ================= LEFT: PRODUCT DETAIL (70%) ================= -->
    <div class="col-lg-8">

        <div class="card card-outline card-primary mb-3">
            <div class="card-header">
                <h5 class="card-title fw-bold mb-0">
                    <i class="bi bi-box me-1"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Tên mặt hàng</label>
                        <input class="form-control" value="Tivi Samsung 55 inch" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Đơn vị tính</label>
                        <input class="form-control" value="Cái" readonly>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Loại hàng</label>
                        <input class="form-control" value="Điện tử" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Nhà cung cấp</label>
                        <input class="form-control" value="Samsung Việt Nam" readonly>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Giá bán</label>
                        <input class="form-control text-danger fw-bold"
                               value="15,000,000" readonly>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Số lượng</label>
                        <input class="form-control" value="20" readonly>
                    </div>
                </div>

                <div>
                    <label class="form-label">Chú thích</label>
                    <textarea class="form-control" rows="3" readonly>
Tivi Samsung 55 inch, độ phân giải 4K, Smart TV
                    </textarea>
                </div>
            </div>

            <div class="card-footer text-end">
                <a href="/Product" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>
                    Quay lại
                </a>
            </div>
        </div>

    </div>

    <!-- ================= RIGHT: ATTRIBUTE + PHOTO (30%) ================= -->
    <!-- ================= RIGHT: ATTRIBUTE + PHOTO (30%) ================= -->
    <div class="col-lg-4">

        <!-- ===== ATTRIBUTE LINK ===== -->
        <div class="card card-outline card-info mb-3">
            <div class="card-header">
                <h6 class="card-title fw-bold mb-0">
                    <i class="bi bi-sliders me-1"></i>
                    Thuộc tính sản phẩm
                </h6>
            </div>

            <div class="card-body text-center">
                <p class="text-muted mb-3">
                    Quản lý các thuộc tính mô tả chi tiết của sản phẩm
                </p>

                <a href="/Product/ListAttributes/1"
                   class="btn btn-outline-info w-100">
                    <i class="bi bi-list-check me-1"></i>
                    Xem danh sách thuộc tính
                </a>
            </div>
        </div>

        <!-- ===== PHOTO LINK ===== -->
        <div class="card card-outline card-success">
            <div class="card-header">
                <h6 class="card-title fw-bold mb-0">
                    <i class="bi bi-images me-1"></i>
                    Hình ảnh sản phẩm
                </h6>
            </div>

            <div class="card-body text-center">
                <p class="text-muted mb-3">
                    Quản lý hình ảnh hiển thị của sản phẩm
                </p>

                <a href="/Product/ListPhoto/1"
                   class="btn btn-outline-success w-100">
                    <i class="bi bi-card-image me-1"></i>
                    Xem danh sách hình ảnh
                </a>
            </div>
        </div>

    </div>


</div>
