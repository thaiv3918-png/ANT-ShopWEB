@using SV22T1020740.BusinessLayers
@model Product
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" enctype="multipart/form-data" action="~/Product/SaveData">
                    @Html.ValidationMessage("Error", new { @class = "text-danger" })
                    <input type="hidden" asp-for="ProductID" />


                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="ProductName"
                                   class="form-control"
                                   placeholder="Nhập tên mặt hàng" autofocus />
                            <span asp-validation-for="ProductName" class="text-danger"></span>

                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng</label>
                        <div class="col-sm-4">
                            <select class="form-select" asp-for="CategoryID" asp-items="await SelectListHelper.CategoriesAsync()">
                            </select>
                            <span asp-validation-for="CategoryID" class="text-danger"></span>
                        </div>
                        
                    </div>
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select class="form-select" asp-for="SupplierID" asp-items="await SelectListHelper.SuppliersAsync()">
                            </select>
                            <span asp-validation-for="SupplierID" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-3">
                            <input type="text" asp-for = "Unit"
                                   class="form-control"
                                   placeholder="cái, hộp, kg..." />
                            <span asp-validation-for="Unit" class="text-danger"></span>
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Giá</label>
                        <div class="col-sm-4">
                            <input type="text" asp-for = "Price"
                                   class="form-control money-input"
                                   placeholder="Giá bán"
                                   min="0" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" asp-for = "IsSelling"
                                       type="checkbox"
                                       id="IsSelling"
                                        />
                                <label class="form-check-label" for="IsSelling">
                                    Đang bán
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <!-- Sử dụng hidden input để lưu giữ tên file ảnh hiện tại của sản phẩm-->
                            <input type="hidden" asp-for="Photo" />
                            <!-- Sử dụng input có name="uploadPhoto" để upload ảnh (tránh không sử dụng name="Photo") -->
                            <input type="file" name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   data-img-preview="imgPreview"
                                   onchange="previewImage(this)" />
                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                     class="img-thumbnail"
                                     style="max-height: 150px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea class="form-control" asp-for = "ProductDescription"
                                      rows="3"
                                      placeholder="Nhập mô tả mặt hàng"></textarea>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@{
    //if (Model.ProductId > 0) {
    @await Html.PartialAsync(
    "ListPhotos",
    await CatalogDataService.ListPhotosAsync(Model.ProductID),
    new ViewDataDictionary(ViewData)
    {
        ["ProductID"] = Model.ProductID
    }
)
    @await Html.PartialAsync(
    "ListAttributes",
    await CatalogDataService.ListAttributesAsync(Model.ProductID),
    new ViewDataDictionary(ViewData)
    {
        ["ProductID"] = Model.ProductID
    }
)
    // }
}