@model SV22T1020740.Models.Common.PagedResult<SV22T1020740.Models.Sales.OrderViewInfo>
@using SV22T1020740.Models.Sales

@if (Model == null || Model.DataItems == null || !Model.DataItems.Any())
{
    <div class="alert alert-info">
        Bạn chưa có đơn hàng nào.
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:120px;">Mã đơn</th>
                            <th style="width:180px;">Ngày đặt</th>
                            <th>Tỉnh/Thành</th>
                            <th>Địa chỉ giao hàng</th>
                            <th style="width:140px;">Trạng thái</th>
                            <th class="text-end" style="width:160px;">Tổng tiền</th>
                            <th style="width:250px;" class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.DataItems)
                        {
                            <tr>
                                <td>
                                    <strong>#@item.OrderID</strong>
                                </td>
                                <td>
                                    @item.OrderTime.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td>
                                    @item.DeliveryProvince
                                </td>
                                <td>
                                    @item.DeliveryAddress
                                </td>
                                <td>
                                    @{
                                        string statusText = "";
                                        string statusClass = "bg-secondary";

                                        switch (item.Status)
                                        {
                                            case OrderStatusEnum.New:
                                                statusText = "Chờ xử lý";
                                                statusClass = "bg-warning text-dark";
                                                break;

                                            case OrderStatusEnum.Accepted:
                                                statusText = "Đã chấp nhận";
                                                statusClass = "bg-info text-dark";
                                                break;

                                            case OrderStatusEnum.Shipping:
                                                statusText = "Đang giao";
                                                statusClass = "bg-primary";
                                                break;

                                            case OrderStatusEnum.Completed:
                                                statusText = "Hoàn tất";
                                                statusClass = "bg-success";
                                                break;

                                            case OrderStatusEnum.Rejected:
                                                statusText = "Từ chối";
                                                statusClass = "bg-danger";
                                                break;

                                            case OrderStatusEnum.Cancelled:
                                                statusText = "Đã hủy";
                                                statusClass = "bg-dark";
                                                break;
                                        }
                                    }

                                    <span class="badge px-2 py-1 @statusClass">
                                        @statusText
                                    </span>
                                </td>
                                <td class="text-end text-danger fw-bold">
                                    @item.TotalPrice.ToString("N0") đ
                                </td>
                                <td class="text-center">
                                    <div class="d-flex flex-wrap gap-2 justify-content-center">
                                        <a href="@Url.Action("Details", "Order", new { id = item.OrderID })"
                                           class="btn btn-sm btn-outline-primary">
                                            Chi tiết
                                        </a>

                                        @if (item.Status == OrderStatusEnum.New)
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger"
                                                    onclick="cancelOrder(@item.OrderID)">
                                                Hủy đơn
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (Model.PageCount > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @if (Model.HasPreviousPage)
                {
                    <li class="page-item">
                        <a href="javascript:void(0)" class="page-link" onclick="loadOrders(@(Model.Page - 1))">&laquo;</a>
                    </li>
                }

                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.Page == 0)
                    {
                        <li class="page-item disabled">
                            <span class="page-link">...</span>
                        </li>
                    }
                    else if (p.Page == Model.Page)
                    {
                        <li class="page-item active">
                            <span class="page-link">@p.Page</span>
                        </li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a href="javascript:void(0)" class="page-link" onclick="loadOrders(@p.Page)">
                                @p.Page
                            </a>
                        </li>
                    }
                }

                @if (Model.HasNextPage)
                {
                    <li class="page-item">
                        <a href="javascript:void(0)" class="page-link" onclick="loadOrders(@(Model.Page + 1))">&raquo;</a>
                    </li>
                }
            </ul>
        </nav>
    }
}