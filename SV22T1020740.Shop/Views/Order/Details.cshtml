@model SV22T1020740.Models.Sales.OrderViewInfo
@using SV22T1020740.Models.Sales

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    var details = ViewBag.OrderDetails as List<OrderDetailViewInfo>;
    decimal totalAmount = details?.Sum(x => x.Quantity * x.SalePrice) ?? 0;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 details-header">
        <h2 class="fw-bold mb-0">Chi tiết đơn hàng #@Model.OrderID</h2>
        <a href="@Url.Action("Index", "Order")" class="btn btn-outline-secondary">
            Quay lại danh sách đơn hàng
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white fw-bold">
            Thông tin đơn hàng
        </div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="info-label">Mã đơn hàng</div>
                    <div class="info-value">#@Model.OrderID</div>
                </div>

                <div class="col-md-4">
                    <div class="info-label">Khách hàng</div>
                    <div class="info-value">@Model.CustomerName</div>
                </div>

                <div class="col-md-4">
                    <div class="info-label">Trạng thái</div>
                    <div class="info-value">
                        @{
                            string statusText = "";
                            string statusClass = "bg-secondary";

                            switch (Model.Status)
                            {
                                case OrderStatusEnum.New:
                                    statusText = "Chờ xử lý";
                                    statusClass = "bg-warning text-dark";
                                    break;

                                case OrderStatusEnum.Accepted:
                                    statusText = "Đã chấp nhận";
                                    statusClass = "bg-info text-dark";
                                    break;

                                case OrderStatusEnum.Shipping:
                                    statusText = "Đang giao";
                                    statusClass = "bg-primary";
                                    break;

                                case OrderStatusEnum.Completed:
                                    statusText = "Hoàn tất";
                                    statusClass = "bg-success";
                                    break;

                                case OrderStatusEnum.Rejected:
                                    statusText = "Từ chối";
                                    statusClass = "bg-danger";
                                    break;

                                case OrderStatusEnum.Cancelled:
                                    statusText = "Đã hủy";
                                    statusClass = "bg-dark";
                                    break;
                            }
                        }

                        <span class="badge px-3 py-2 fs-6 @statusClass">
                            @statusText
                        </span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="info-label">Ngày đặt</div>
                    <div class="info-value">
                        @Model.OrderTime.ToString("dd/MM/yyyy HH:mm:ss")
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="info-label">Ngày duyệt</div>
                    <div class="info-value">
                        @(Model.AcceptTime.HasValue
                                                ? Model.AcceptTime.Value.ToString("dd/MM/yyyy HH:mm:ss")
                                                : "Chưa duyệt")
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="info-label">Ngày giao vận</div>
                    <div class="info-value">
                        @(Model.ShippedTime.HasValue
                                                ? Model.ShippedTime.Value.ToString("dd/MM/yyyy HH:mm:ss")
                                                : "Chưa giao vận")
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="info-label">Ngày hoàn tất</div>
                    <div class="info-value">
                        @(Model.FinishedTime.HasValue
                                                ? Model.FinishedTime.Value.ToString("dd/MM/yyyy HH:mm:ss")
                                                : "Chưa hoàn tất")
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="info-label">Tỉnh/Thành giao hàng</div>
                    <div class="info-value">@Model.DeliveryProvince</div>
                </div>

                <div class="col-md-4">
                    <div class="info-label">Địa chỉ giao hàng</div>
                    <div class="info-value">@Model.DeliveryAddress</div>
                </div>

                <div class="col-md-6">
                    <div class="info-label">Nhân viên xử lý</div>
                    <div class="info-value">
                        @(string.IsNullOrWhiteSpace(Model.EmployeeName) ? "Chưa có" : Model.EmployeeName)
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="info-label">Đơn vị giao hàng</div>
                    <div class="info-value">
                        @(string.IsNullOrWhiteSpace(Model.ShipperName) ? "Chưa có" : Model.ShipperName)
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white fw-bold">
            Sản phẩm trong đơn hàng
        </div>
        <div class="card-body p-0">
            @if (details == null || !details.Any())
            {
                <div class="p-3 text-muted">
                    Không có sản phẩm trong đơn hàng.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center" style="width:120px;">Số lượng</th>
                                <th class="text-end" style="width:160px;">Đơn giá</th>
                                <th class="text-end" style="width:180px;">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in details)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@item.ProductName</div>
                                    </td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">@item.SalePrice.ToString("N0") đ</td>
                                    <td class="text-end fw-bold text-danger">
                                        @((item.Quantity * item.SalePrice).ToString("N0")) đ
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <th colspan="3" class="text-end">Tổng cộng</th>
                                <th class="text-end text-danger fs-5">
                                    @totalAmount.ToString("N0") đ
                                </th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="mt-4 d-flex gap-2 flex-wrap">
        @if (Model.Status == OrderStatusEnum.New)
        {
            <button type="button" class="btn btn-outline-danger" onclick="cancelOrder(@Model.OrderID)">
                Hủy đơn hàng
            </button>
        }
    </div>
</div>

<style>
    .badge {
        border-radius: 20px;
    }
    .info-label {
        font-size: 13px;
        color: #6c757d;
        margin-bottom: 6px;
    }

    .info-value {
        font-size: 18px;
        font-weight: 600;
        min-height: 28px;
        word-break: break-word;
    }

    @@media (max-width: 768px) {
        .details-header {
            flex-direction: column;
            align-items: stretch !important;
            gap: 12px;
        }

            .details-header .btn {
                width: 100%;
            }

        .info-value {
            font-size: 16px;
        }
    }
</style>

@section scripts {
    <script>
        function cancelOrder(orderId) {
            if (!confirm("Bạn có chắc muốn hủy đơn hàng này không?")) {
                return;
            }

            fetch('@Url.Action("Cancel", "Order")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'id=' + encodeURIComponent(orderId)
            })
            .then(response => response.json())
            .then(data => {
                if (data.code > 0) {
                    alert(data.message || "Hủy đơn thành công");
                    window.location.href = '@Url.Action("Index", "Order")';
                } else {
                    alert(data.message || "Không thể hủy đơn");
                }
            })
            .catch(() => {
                alert("Lỗi hệ thống");
            });
        }
    </script>
}