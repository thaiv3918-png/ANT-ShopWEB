@{
    ViewData["Title"] = "Trang chủ";
}

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-6">
                <div class="hero-content">
                    <span class="hero-badge">Chào mừng đến với ANT SHOP</span>
                    <h1 class="hero-title">
                        Mua sắm tiện lợi, nhanh chóng và đáng tin cậy
                    </h1>
                    <p class="hero-desc">
                        ANT SHOP cung cấp nhiều sản phẩm chất lượng với trải nghiệm mua sắm đơn giản,
                        giao diện thân thiện và hỗ trợ khách hàng nhanh chóng.
                    </p>

                    <div class="hero-actions">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg hero-btn">
                            Khám phá sản phẩm
                        </a>
                    </div>

                    <div class="hero-stats">
                        <div class="stat-box">
                            <h4>1000+</h4>
                            <p>Sản phẩm</p>
                        </div>
                        <div class="stat-box">
                            <h4>24/7</h4>
                            <p>Hỗ trợ</p>
                        </div>
                        <div class="stat-box">
                            <h4>Nhanh</h4>
                            <p>Giao hàng</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="hero-image-card">
                    <div class="hero-image-overlay"></div>
                    <img src="https://images.unsplash.com/photo-1556740749-887f6717d7e4?q=80&w=1200&auto=format&fit=crop"
                         alt="ANT SHOP"
                         class="hero-image" />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="quick-links-section">
    <div class="container">
        <div class="row g-4 justify-content-center">

            <div class="col-md-4">
                <a asp-controller="Product" asp-action="Index" class="quick-card text-decoration-none">
                    <div class="quick-icon">🛍️</div>
                    <h4>Sản phẩm</h4>
                    <p>Khám phá hàng ngàn sản phẩm chất lượng.</p>
                </a>
            </div>

            <div class="col-md-4">
                <a asp-controller="Order" asp-action="Cart" class="quick-card text-decoration-none">
                    <div class="quick-icon">🛒</div>
                    <h4>Giỏ hàng</h4>
                    <p>Xem và quản lý giỏ hàng của bạn.</p>
                </a>
            </div>

        </div>
    </div>
</section>

<section class="feature-section">
    <div class="container">
        <div class="section-title text-center mb-5">
            <h2>Tại sao nên chọn ANT SHOP?</h2>
            <p>Trải nghiệm mua sắm hiện đại, thân thiện và hiệu quả.</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">✅</div>
                    <h5>Sản phẩm chất lượng</h5>
                    <p>Danh mục hàng hóa rõ ràng, thông tin đầy đủ, hỗ trợ lựa chọn nhanh chóng.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">⚡</div>
                    <h5>Đặt hàng nhanh</h5>
                    <p>Từ xem sản phẩm, thêm giỏ hàng đến đặt đơn chỉ trong vài thao tác đơn giản.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">📞</div>
                    <h5>Hỗ trợ tận tâm</h5>
                    <p>Luôn sẵn sàng hỗ trợ khách hàng trong suốt quá trình mua sắm và theo dõi đơn.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="contact-section">
    <div class="container">

        <div class="social-links text-center mt-4">
            <a href="#" class="social-btn">Facebook</a>
            <a href="#" class="social-btn">Zalo</a>
            <a href="#" class="social-btn">Instagram</a>
            <a href="#" class="social-btn">YouTube</a>
        </div>
    </div>
</section>

<style>
    .hero-section {
        background: linear-gradient(135deg, #0d6efd 0%, #4f8dfd 100%);
        color: white;
        padding: 70px 0;
        border-radius: 0 0 28px 28px;
        margin-bottom: 40px;
    }

    .hero-badge {
        display: inline-block;
        padding: 8px 14px;
        background: rgba(255,255,255,0.15);
        border-radius: 999px;
        font-size: 14px;
        margin-bottom: 18px;
    }

    .hero-title {
        font-size: 48px;
        font-weight: 800;
        line-height: 1.2;
        margin-bottom: 18px;
    }

    .hero-desc {
        font-size: 18px;
        line-height: 1.7;
        opacity: 0.95;
        margin-bottom: 26px;
        max-width: 620px;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 30px;
    }

    .hero-btn,
    .hero-btn-outline {
        border-radius: 12px;
        padding: 12px 22px;
        font-weight: 600;
    }

    .hero-btn-outline {
        border: 1px solid rgba(255,255,255,0.8);
        color: white;
    }

        .hero-btn-outline:hover {
            background: white;
            color: #0d6efd;
        }

    .hero-stats {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .stat-box {
        background: rgba(255,255,255,0.12);
        border-radius: 16px;
        padding: 16px 20px;
        min-width: 120px;
        text-align: center;
    }

        .stat-box h4 {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
        }

        .stat-box p {
            margin: 6px 0 0;
            font-size: 14px;
        }

    .hero-image-card {
        position: relative;
        overflow: hidden;
        border-radius: 24px;
        box-shadow: 0 16px 40px rgba(0,0,0,0.18);
        min-height: 420px;
    }

    .hero-image {
        width: 100%;
        height: 100%;
        min-height: 420px;
        object-fit: cover;
        display: block;
    }

    .hero-image-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.18), transparent);
        z-index: 1;
    }

    .quick-links-section,
    .feature-section,
    .contact-section {
        padding-bottom: 40px;
    }

    .quick-card {
        display: block;
        background: white;
        border-radius: 20px;
        padding: 28px 24px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.07);
        transition: all 0.25s ease;
        height: 100%;
        color: inherit;
    }

        .quick-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 34px rgba(0,0,0,0.12);
        }

    .quick-icon {
        font-size: 34px;
        margin-bottom: 14px;
    }

    .quick-card h4 {
        font-weight: 700;
        margin-bottom: 10px;
    }

    .quick-card p {
        color: #6c757d;
        margin-bottom: 0;
        line-height: 1.7;
    }

    .section-title h2 {
        font-size: 34px;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .section-title p {
        color: #6c757d;
        margin-bottom: 0;
    }

    .feature-card {
        background: white;
        border-radius: 20px;
        padding: 28px 24px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
        height: 100%;
    }

    .feature-icon {
        font-size: 36px;
        margin-bottom: 14px;
    }

    .feature-card h5 {
        font-weight: 700;
        margin-bottom: 10px;
    }

    .feature-card p {
        color: #6c757d;
        line-height: 1.7;
        margin-bottom: 0;
    }

    .contact-card {
        background: linear-gradient(135deg, #ffffff, #f8fbff);
        border-radius: 24px;
        padding: 34px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    }

        .contact-card h2 {
            font-size: 34px;
            font-weight: 800;
            margin-bottom: 12px;
        }

        .contact-card p {
            color: #6c757d;
            line-height: 1.7;
        }

    .contact-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 18px;
    }

    .contact-item {
        display: flex;
        gap: 14px;
        background: white;
        border-radius: 16px;
        padding: 18px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.05);
        align-items: flex-start;
    }

    .contact-item-icon {
        font-size: 26px;
        line-height: 1;
    }

    .contact-item h6 {
        margin: 0 0 6px;
        font-weight: 700;
    }

    .contact-item p {
        margin: 0;
        color: #6c757d;
    }

    .social-links {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 12px;
    }

    .social-btn {
        display: inline-block;
        padding: 10px 18px;
        border-radius: 999px;
        background: #0d6efd;
        color: white;
        text-decoration: none;
        font-weight: 600;
        transition: 0.25s ease;
    }

        .social-btn:hover {
            background: #0b5ed7;
            color: white;
        }

    @@media (max-width: 991.98px) {
        .hero-title {
            font-size: 38px;
        }

        .contact-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 767.98px) {
        .hero-section {
            padding: 50px 0;
        }

        .hero-title {
            font-size: 32px;
        }

        .hero-desc {
            font-size: 16px;
        }

        .contact-card {
            padding: 24px;
        }

            .section-title h2,
            .contact-card h2 {
                font-size: 28px;
            }
    }
</style>